{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "baseUrl": "./",
    "jsx": "react-jsx",
    "paths": {
      "@/core": ["src/features/core"],
      "@/roster": ["src/features/roster"],
      "@/scripts/*": ["scripts/*"],
      "@/settings": ["src/features/settings"],
      "@/src/*": ["src/*"],
      "@/test/*": ["test/*"]
    },
    "rootDir": "./",
    "types": ["vite/client", "vitest/globals"]
  },
  "exclude": ["dist", "node_modules"],
  "extends": "@powercoach/config/tsconfig.test.json",
  "include": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "test/**/*.ts",
    "test/**/*.tsx",
    "scripts/**/*.test.ts"
  ]
}
