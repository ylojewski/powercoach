{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "baseUrl": "./",
    "jsx": "react-jsx",
    "outDir": "dist",
    "paths": {
      "@/core": ["src/features/core"],
      "@/exercises": ["src/features/exercises"],
      "@/roster": ["src/features/roster"],
      "@/scripts/*": ["scripts/*"],
      "@/settings": ["src/features/settings"],
      "@/src/*": ["src/*"],
      "@/test/*": ["test/*"]
    },
    "rootDir": "./",
    "types": ["vite/client"]
  },
  "exclude": [
    "dist",
    "node_modules",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "scripts/**/*.test.ts",
    "test"
  ],
  "extends": "@powercoach/config/tsconfig.src.json",
  "include": ["src", "scripts"]
}
